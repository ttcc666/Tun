{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "PublicHttp": {
        "Url": "http://127.0.0.1:8080",
        "Protocols": "Http1"
      },
      "TunnelGrpc": {
        "Url": "http://127.0.0.1:8081",
        "Protocols": "Http2"
      }
    }
  },
  "Tun": {
    "Token": "dev-token",
    "ManagementToken": "dev-token",
    "ConfigPath": "data/tunnels.json",
    "Database": {
      "Enabled": true,
      "ConnectionString": "Host=localhost;Port=5432;Database=tun;Username=postgres;Password=123456"
    },
    "ForwardedHeaders": {
      "Enabled": true,
      "ForwardHost": true,
      "ForwardLimit": 1,
      "AllowedHosts": []
    },
    "ConfiguredTunnels": [
      {
        "TunnelId": "demo",
        "ClientId": "dev-client",
        "LocalUrl": "http://localhost:5000",
        "Enabled": true,
        "Description": "Sample app tunnel"
      }
    ],
    "ChunkSize": 65536,
    "RequestTimeoutSeconds": 60,
    "IdleTimeoutSeconds": 120
  },
  "AllowedHosts": "*"
}
