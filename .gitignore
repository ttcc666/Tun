## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.csproj.DotSettings.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build log of MSBuild
*.aps
*.intermediate.manifest
*.pfx
*.publishsettings
*.resources
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.vspscc
*.vssscc
.buildlog
*.g.cs
*.g.i.cs

# ReSharper is a .NET coding add-in
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustMock - testing framework
Libraries/

# SonarLint for Visual Studio
.sonarlint/

# Visual Studio Store app package directories
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt
*.appx
*.appxbundle
*.appxcfg

# Visual Studio entities
*.ssdir

# Tasks
ServiceFabricBackup/

# Output of MSBuild (e.g. env-specific appsettings.json)
# [Aa]ppsettings.*.json

# All local-only files
*.local.json

# Others
ClientBin/
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
orleans.codegen.cs

# Since there are multiple projects, we should be careful.
# But generally bin/obj are always ignored in .NET.
**/[Bb]in/
**/[Oo]bj/

# User-specific project settings
*.csproj.user
*.sqlproj.user
*.pubxml
*.pubxml.user

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
wwwroot/lib/

# Entity Framework Core
*.design.time.cache

# ncrunch stuff
*ncrunch*
*crunch*
*_ncrunch*
*._ncrunch*
NTDS.dat*

# Solutions
*.sln
# Wait, Tun.slnx is a new solution format, let's keep it unless user says otherwise.
# But usually .sln is kept.

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# Environment Variables
.env
.env.*

# Local data
**/data/tunnels.json
